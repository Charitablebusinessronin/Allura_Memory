#!/usr/bin/env bash
#
# Pre-commit hook: Enforce TypeScript type checking and prevent secrets
# Memory rule: Contracts must be honored. The type system is the canary.
#

set -e

# ─────────────────────────────────────────────────────────────────────────────
# 1. TypeScript Type Check
# ─────────────────────────────────────────────────────────────────────────────

echo "🔍 Running TypeScript type check..."
bun run typecheck

if [ $? -ne 0 ]; then
  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "❌ TypeScript errors found. Fix before committing."
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
  echo "Memory rule: Contracts must be honored."
  echo ""
  echo "The type system is the canary. When it sings,"
  echo "contracts have diverged. A developer changed"
  echo "an interface without updating consumers."
  echo ""
  echo "Fix the errors, then commit again."
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  exit 1
fi

echo "✅ Type check passed"

# ─────────────────────────────────────────────────────────────────────────────
# 2. Prevent .env Files with Secrets
# ─────────────────────────────────────────────────────────────────────────────

# Check for .env files with potential secrets (but allow .env.example template)
forbidden_files=$(git diff --cached --name-only | grep -E '\.env$|\.env\.local$|\.env\.decrypted$|\.env\.backup$' || true)

if [ -n "$forbidden_files" ]; then
  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "❌ ERROR: Attempting to commit .env files with potential secrets:"
  echo "$forbidden_files"
  echo ""
  echo "These files may contain sensitive credentials and should not be committed."
  echo "If you need to commit environment templates, use .env.example with placeholder values."
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  exit 1
fi

# Check for potential secrets in committed files
secrets_pattern='(password|secret|api_key|token|credential)\s*=\s*[^$].*'

if git diff --cached | grep -iE "$secrets_pattern" | grep -v 'your_.*_here' | grep -v 'placeholder' > /dev/null 2>&1; then
  echo "⚠️  WARNING: Potential secrets detected in staged changes"
  echo "Please ensure no real credentials are being committed"
fi

echo "✅ No secrets detected"
exit 0