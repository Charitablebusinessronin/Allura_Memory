{
  "servers": {
    "allura-memory": {
      "type": "http",
      "url": "http://localhost:5888/mcp"
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?exaApiKey=${EXA_API_KEY}"
    },
    "browserOS": {
      "type": "stdio",
      "command": "npx",
      "args": ["mcp-remote", "http://127.0.0.1:9000/mcp"]
    },
    "MCP_DOCKER": {
      "command": "docker",
      "args": ["mcp", "gateway", "run"],
      "type": "stdio"
    }
  }
}