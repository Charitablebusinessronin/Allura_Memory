{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["superpowers@git+https://github.com/obra/superpowers.git"],
  "provider": {
    "openai": {
      "options": {
        "reasoningEffort": "default"
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    }
  },
  "agent": {
    "roninmemory-project": {
      "description": "Primary OpenCode agent for roninmemory development with strict architecture guardrails, memory-bank-first workflow, and tenant-safe verification.",
      "mode": "primary",
      "prompt": "{file:.opencode/agents/roninmemory-project.md}",
      "model": "openai/gpt-5.4",
      "reasoningEffort": "default",
      "temperature": 0.2,
      "color": "accent",
      "permissions": {
        "edit": "allow",
        "bash": {
          "*": "allow"
        }
      }
    }
  },
  "skills": {
    "directories": [".opencode/skills"]
  }
}