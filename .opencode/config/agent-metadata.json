{
  "$schema": "https://opencode.ai/schemas/agent-metadata.json",
  "schema_version": "1.0.0",
  "description": "Centralized metadata for RoninMemory agents. Memory-themed agent registry for the unified AI brain.",
  "agents": {
    "memory-orchestrator": {
      "id": "memory-orchestrator",
      "name": "MemoryOrchestrator",
      "category": "agent",
      "type": "agent",
      "version": "1.0.0",
      "author": "roninmemory",
      "path": ".opencode/agent/MemoryOrchestrator.md",
      "tags": ["memory-system", "orchestration", "primary", "brooks", "planning", "governance"],
      "persona": {
        "name": "Frederick P. Brooks Jr.",
        "style": "direct, pragmatic, conceptually-integrated, high-signal",
        "source": "https://www.notion.so/3181d9be65b3805da320eace4cd56d2b",
        "core_principles": [
          "conceptual_integrity_above_all",
          "data_dominates",
          "minimize_communication_overhead",
          "subagents_execute_orchestrator_governs",
          "no_premature_abstraction"
        ]
      },
      "operating_model": {
        "execution_layer": "subagents",
        "party_mode_skill": "bmad-party-mode",
        "party_mode_enabled": true
      },
      "tenant_boundary": {
        "memory_partition_key": "group_id",
        "global_partition_key": "global-coding-skills"
      },
      "memory_system": {
        "enabled": true,
        "hydration_required": true,
        "stores": ["postgres", "neo4j"],
        "logging_mode": "dual",
        "readback_required": true
      },
      "scope": "OpenCode CLI Agent - Winston's hands for orchestration"
    },
    "memory-architect": {
      "id": "memory-architect",
      "name": "MemoryArchitect",
      "category": "agent",
      "type": "agent",
      "version": "1.0.0",
      "author": "roninmemory",
      "path": ".opencode/agent/MemoryArchitect.md",
      "tags": ["memory-system", "architecture", "implementation", "design"],
      "scope": "OpenCode CLI Agent - Winston's hands for system design",
      "dependencies": [
        "skill:bmad-create-architecture",
        "context:standards-code",
        "context:standards-docs"
      ]
    },
    "memory-builder": {
      "id": "memory-builder",
      "name": "MemoryBuilder",
      "category": "agent",
      "type": "agent",
      "version": "1.0.0",
      "author": "roninmemory",
      "path": ".opencode/agent/MemoryBuilder.md",
      "tags": ["memory-system", "infrastructure", "docker", "payload"],
      "scope": "OpenCode CLI Agent - Winston's hands for infrastructure",
      "dependencies": [
        "context:standards-code",
        "tool:mcp-docker"
      ]
    },
    "memory-analyst": {
      "id": "memory-analyst",
      "name": "MemoryAnalyst",
      "category": "agent",
      "type": "agent",
      "version": "1.0.0",
      "author": "roninmemory",
      "path": ".opencode/agent/MemoryAnalyst.md",
      "tags": ["memory-system", "analytics", "metrics", "performance"],
      "scope": "OpenCode CLI Agent - Winston's hands for memory system analysis",
      "dependencies": [
        "context:standards-code",
        "tool:mcp-docker"
      ]
    },
    "memory-copywriter": {
      "id": "memory-copywriter",
      "name": "MemoryCopywriter",
      "category": "agent",
      "type": "agent",
      "version": "1.0.0",
      "author": "roninmemory",
      "path": ".opencode/agent/MemoryCopywriter.md",
      "tags": ["memory-system", "documentation", "prompts", "communication"],
      "scope": "OpenCode CLI Agent - Winston's hands for agent prompt writing",
      "dependencies": [
        "context:standards-docs"
      ]
    },
    "memory-repo-manager": {
      "id": "memory-repo-manager",
      "name": "MemoryRepoManager",
      "category": "agent",
      "type": "agent",
      "version": "1.0.0",
      "author": "roninmemory",
      "path": ".opencode/agent/MemoryRepoManager.md",
      "tags": ["memory-system", "git", "repository", "coordination"],
      "scope": "OpenCode CLI Agent - Winston's hands for repository management",
      "dependencies": [
        "context:standards-code",
        "tool:git"
      ]
    },
    "memory-scribe": {
      "id": "memory-scribe",
      "name": "MemoryScribe",
      "category": "agent",
      "type": "agent",
      "version": "1.0.0",
      "author": "roninmemory",
      "path": ".opencode/agent/MemoryScribe.md",
      "tags": ["memory-system", "documentation", "specs", "prd"],
      "scope": "OpenCode CLI Agent - Winston's hands for documentation and specs",
      "dependencies": [
        "skill:bmad-create-prd",
        "context:standards-docs"
      ]
    }
  },
  "two_world_model": {
    "description": "Two separate agent worlds - OpenCode CLI agents (Winston's hands) and Org/Business agents (digital employees)",
    "opencode_agents": {
      "location": ".opencode/agent/",
      "runtime": "Terminal / OpenCode",
      "naming": "Memory{Role}",
      "count": 7,
      "purpose": "How Winston works"
    },
    "org_agents": {
      "location": "Paperclip / OpenClaw",
      "runtime": "Paperclip dashboard",
      "naming": "{org}-agent",
      "purpose": "What works FOR clients/orgs",
      "examples": ["faithmeats-agent", "audits-agent", "crm-agent", "nonprofit-agent"],
      "blocked_on": "groupIdEnforcer.ts fix"
    }
  },
  "defaults": {
    "agent": {
      "version": "1.0.0",
      "author": "roninmemory",
      "type": "agent",
      "tags": ["memory-system"],
      "scope": "OpenCode CLI Agent",
      "tier": "agent",
      "group_id": "roninmemory-system",
      "behavior_lock": "UNPROMOTED",
      "memory_bootstrap": true,
      "steps": [1,2,3,4,5,6,7,8,9]
    }
  }
}