      "type": "subagent",
      "version": "1.0.0",
      "author": "roninmemory",
      "path": ".opencode/agent/subagents/system-builder/domain-analyzer.md",
      "tags": ["memory-system", "system-builder", "analysis"],
      "scope": "OpenCode Subagent - extracts domain concepts and recommended agent structure",
