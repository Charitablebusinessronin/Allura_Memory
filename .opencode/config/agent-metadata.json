  "archived_agents": {
    "memory-copywriter": {
      "id": "memory-copywriter",
      "path": ".opencode/agent/archive/MemoryCopywriter.md",
      "reason": "Consolidated into MemoryChronicler",
      "status": "inactive"
    },
    "memory-repo-manager": {
      "id": "memory-repo-manager",
      "path": ".opencode/agent/archive/MemoryRepoManager.md",
      "reason": "Git operations handled by MemoryBuilder",
      "status": "inactive"
    },
    "memory-scribe": {
      "id": "memory-scribe",
      "path": ".opencode/agent/archive/MemoryScribe.md",
      "reason": "Consolidated into MemoryChronicler",
      "status": "inactive"
    }
  },
  "surgical_team": {
    "description": "The Surgical Team model - chief surgeon coordinates, subagents execute",
    "sequence": [
      {"step": 1, "agent": "memory-scout", "action": "discover", "approval_required": false},
      {"step": 2, "agent": "memory-architect", "action": "design", "approval_required": true},
      {"step": 3, "agent": "memory-orchestrator", "action": "approve", "approval_required": false},
      {"step": 4, "agent": "memory-builder", "action": "implement", "approval_required": true},
      {"step": 5, "agent": "memory-guardian", "action": "validate", "approval_required": false},
      {"step": 6, "agent": "memory-chronicler", "action": "document", "approval_required": false}
    ],
    "brooks_law": "Adding subagents to a late workflow makes it later. Communication overhead grows as n(n-1)/2."
  },
  "two_world_model": {
    "description": "Two separate agent worlds - OpenCode CLI agents (Winston's hands) and Org/Business agents (digital employees)",
    "opencode_agents": {
      "location": ".opencode/agent/",
      "runtime": "Terminal / OpenCode",
      "naming": "Memory{Role}",
      "count": 7,
      "purpose": "How Winston works"
    },
    "org_agents": {
      "location": "Paperclip / OpenClaw",
      "runtime": "Paperclip dashboard",
      "naming": "{org}-agent",
      "purpose": "What works FOR clients/orgs",
      "examples": ["faithmeats-agent", "audits-agent", "crm-agent", "nonprofit-agent"],
      "blocked_on": "groupIdEnforcer.ts fix"
    }
  },
  "defaults": {
    "agent": {
      "version": "2.0.0",
      "author": "roninmemory",
      "type": "agent",
      "tags": ["memory-system"],
      "scope": "OpenCode CLI Agent",
      "tier": "agenallura-roninmemory",
      "behavior_lock": "UNPROMOTED",
      "memory_bootstrap": true,
      "ai_guidelines_path": "AI-GUIDELINES.md",
      "documentation_template": "templates/PROJECT.template.md"
    }
  }
}