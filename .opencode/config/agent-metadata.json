        "subagent:memory-tester",
        "subagent:memory-guardian",
        "subagent:memory-validator",
        "context:project-intelligence",
        "tool:mcp-docker"
      ],
      "memory_system": {
        "enabled": true,
        "stores": ["postgres", "neo4j"],
        "hitl_required": true,
        "versioning": "steel-frame",
        "mcp_docker_required": true
