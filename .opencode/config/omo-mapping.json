{
  "$schema": "omo-mapping-v1",
  "description": "OMO (oh-my-openagent) → Allura Brain Team RAM mapping. This is the translation layer between the OMO framework's built-in agent roles and this project's team naming. The OMO framework provides the base capability model; the names and routing below are project-scoped.",
  "version": 1,

  "core": {
    "sisyphus": {
      "omo_role": "orchestrator",
      "maps_to": "brooks",
      "agent_file": ".opencode/agent/brooks.md",
      "mode": "primary",
      "priority": "core"
    },
    "hephaestus": {
      "omo_role": "builder",
      "maps_to": "woz",
      "agent_file": ".opencode/agent/woz.md",
      "mode": "subagent",
      "priority": "core"
    },
    "prometheus": {
      "omo_role": "reasoner",
      "maps_to": "norvig",
      "agent_file": ".opencode/agent/norvig.md",
      "mode": "subagent",
      "priority": "core",
      "status": "new"
    },
    "atlas": {
      "omo_role": "context_holder",
      "maps_to": "hassabis",
      "agent_file": ".opencode/agent/hassabis.md",
      "mode": "subagent",
      "priority": "core",
      "status": "new"
    }
  },

  "specialists": {
