    "woz": ["executes", "implements", "ships working code"],
    "torvalds": ["validates before finalize", "brutal correctness", "critique"],
    "jim-simons": ["logs", "learns", "memory retrieval", "data patterns"],
    "karpathy": ["knowledge answers", "ML/AI expertise"],
    "fei-fei-li-vision": ["vision", "images", "multimodal"],
    "pike": ["interfaces", "surface area", "simplicity"],
    "bellard": ["diagnostics", "measurement", "low-level performance"],
    "fowler": ["refactoring", "maintainability", "incremental change"],
    "carmack": ["optimization", "latency", "real-time performance"],
    "knuth": ["schema", "queries", "data architecture"],
    "hightower": ["deployment", "ci/cd", "infrastructure"],
    "sutskever": ["strategy", "wisdom", "long-term thinking"],
    "operator": ["helper", "subtask", "delegated work"]
  }
