  "existing_team_ram": {
    "brooks": { "omo_equivalent": "sisyphus", "role": "architect + orchestrator" },
    "jobs": { "omo_equivalent": null, "role": "intent gate", "note": "No OMO equivalent — unique to Allura Brain" },
    "woz": { "omo_equivalent": "hephaestus", "role": "primary builder" },
    "pike": { "omo_equivalent": null, "role": "interface gate", "note": "No OMO equivalent — unique to Allura Brain" },
    "bellard": { "omo_equivalent": null, "role": "diagnostics + perf", "note": "No OMO equivalent — unique to Allura Brain" },
    "fowler": { "omo_equivalent": null, "role": "refactor gate", "note": "No OMO equivalent — unique to Allura Brain" },
    "carmack": { "omo_equivalent": null, "role": "performance specialist", "note": "No OMO equivalent — unique to Allura Brain" },
