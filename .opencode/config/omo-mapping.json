    "hassabis": { "omo_equivalent": "atlas", "role": "context + big picture" },
    "karpathy": { "omo_equivalent": "oracle", "role": "knowledge + AI expertise" },
    "jim-simons": { "omo_equivalent": "librarian", "role": "memory + data patterns" },
