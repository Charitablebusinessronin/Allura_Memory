# roninmemory .opencode environment reference
# Copy to .env.local (or your secret manager) and provide real values.

# ------------------------------
# PostgreSQL (raw traces)
# ------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=memory
POSTGRES_USER=ronin4life
POSTGRES_PASSWORD=change_me

# ------------------------------
# Neo4j (curated graph)
# ------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me
NEO4J_DATABASE=neo4j

# ------------------------------
# MCP / Research APIs
# ------------------------------
TAVILY_API_KEY=
CONTEXT7_API_KEY=

# Optional model providers (only if used)
GEMINI_API_KEY=
MINIMAX_API_KEY=

# Notes:
# - For MCP containerized runtimes, Neo4j URI may need: bolt://host.docker.internal:7687
# - Never commit real secrets.
