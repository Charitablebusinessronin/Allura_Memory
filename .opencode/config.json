{
  "$schema": "https://opencode.ai/config.json",
  "yolo": true,
  "model": "gpt-5.5",
  "instructions": [
    ".opencode/AGENTS.md",
    ".opencode/manifest.json",
    ".opencode/SKILL-OWNERSHIP.md",
    ".opencode/context/core/context-system.md",
    ".opencode/context/navigation.md",
    ".opencode/agent/core/brooks.md",
    ".opencode/agent/core/jobs.md",
    ".agents/TEAM-RAM-RUNTIME.md",
    ".opencode/COWORK.md"
  ],
  "mcp": {
    "notion": {
      "type": "remote",
      "url": "http://host.docker.internal:3000/mcp"
    },
    "allura-brain": {
      "type": "remote",
      "url": "http://localhost:5888/mcp"
    }
  },
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "bash": "allow",
    "edit": "allow",
    "write": "allow",
    "skill": {
      "allura-memory-skill": "allow",
      "mcp-docker": "allow",
      "team-ram-cowork": "allow",
      "*": "allow"
    },
    "task": "allow"
  },
  "runtime_contract": {
    "active_notion_contract_scope": "https://www.notion.so/ce13dc069ff347689fcc7cbe188232c8",
    "canonical_plan_id": "ce13dc069ff347689fcc7cbe188232c8",
    "canonical_plan_path": "ralph/PROMPT_plan.md",
    "required_context_files": [
      ".opencode/AGENTS.md",
      ".opencode/manifest.json",
      ".opencode/SKILL-OWNERSHIP.md",
      ".opencode/context/core/context-system.md",
      ".opencode/context/navigation.md",
      ".opencode/agent/core/brooks.md",
      ".opencode/agent/core/jobs.md"
    ],
    "required_skills": [
      "allura-memory-skill",
      "mcp-docker"
    ],
    "validation_commands": [
      "bun test src/lib/validation/group-id.test.ts"
    ],
    "discovery_preference": [
      "notion",
      "notion-remote"
    ]
  },
  "agent": {
    "brooks": {
      "mode": "primary",
      "path": ".opencode/agents/core/brooks.md",
      "permission": {
        "task": "allow",
        "skill": {
          "*": "allow"
        }
      }
    },
    "jobs": {
      "mode": "primary",
      "path": ".opencode/agents/core/jobs.md",
      "permission": {
        "skill": {
          "*": "allow"
        }
      }
    },
    "scout": {
      "mode": "subagent",
      "path": ".opencode/agents/subagents/core/scout.md",
      "permission": {
        "edit": "deny",
        "write": "deny",
        "task": "deny",
        "skill": {
          "*": "allow"
        }
      }
    },
    "woz": {
      "mode": "subagent",
      "path": ".opencode/agents/subagents/code/woz.md",
      "permission": {
        "task": "allow",
        "skill": {
          "*": "allow"
        }
      }
    },
    "bellard": {
      "mode": "subagent",
      "path": ".opencode/agents/subagents/code/bellard.md",
      "permission": {
        "skill": {
          "*": "allow"
        }
      }
    },
    "carmack": {
      "mode": "subagent",
      "path": ".opencode/agents/subagents/code/carmack.md",
      "permission": {
        "skill": {
          "*": "allow"
        }
      }
    },
    "pike": {
      "mode": "subagent",
      "path": ".opencode/agents/subagents/review/pike.md",
      "permission": {
        "skill": {
          "*": "allow"
        }
      }
    },
    "fowler": {
      "mode": "subagent",
      "path": ".opencode/agents/subagents/review/fowler.md",
      "permission": {
        "skill": {
          "*": "allow"
        }
      }
    },
    "knuth": {
      "mode": "subagent",
      "path": ".opencode/agents/subagents/infrastructure/knuth.md",
      "permission": {
        "skill": {
          "*": "allow"
        }
      }
    },
    "hightower": {
      "mode": "subagent",
      "path": ".opencode/agents/subagents/infrastructure/hightower.md",
      "permission": {
        "skill": {
          "*": "allow"
        }
      }
    }
  }
}
