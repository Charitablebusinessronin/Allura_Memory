{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "webfetch": "allow",
    "bash": "ask",
    "edit": "ask",
    "write": "ask",
    "skill": {
      "allura-menu": "allow",
      "bun-security": "allow",
      "code-review": "allow",
      "github": "allow",
      "hitl-governance": "allow",
      "mcp-builder": "allow",
      "mcp-docker": "allow",
      "mcp-docker-memory-system": "allow",
      "memory-client": "allow",
      "multi-search": "allow",
      "next-best-practices": "allow",
      "party-mode": "allow",
      "postgres-best-practices": "allow",
      "quick-update": "allow",
      "readme-memory": "allow",
      "skill-creator": "allow",
      "superpowers-memory": "allow",
      "systematic-debugging-memory": "allow",
      "task-creator": "allow",
      "task-management": "allow",
      "trailofbits-audit": "allow"
    }
  },
  "instructions": [
    ".opencode/AGENTS.md",
    ".claude/rules/_bootstrap.md",
    ".claude/rules/agent-routing.md",
    ".claude/rules/mcp-integration.md",
    ".claude/rules/AI-GUIDELINES.md"
  ],
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "mcpServers": {
    "allura-memory": {
      "command": "bun",
      "args": [
        "run",
        "src/mcp/memory-server-canonical.ts"
      ],
      "env": {
        "POSTGRES_HOST": "localhost",
        "POSTGRES_PORT": "5432",
        "POSTGRES_USER": "ronin4life",
        "POSTGRES_PASSWORD": "${POSTGRES_PASSWORD}",
        "POSTGRES_DB": "memory",
        "NEO4J_URI": "bolt://localhost:7687",
        "NEO4J_USER": "neo4j",
        "NEO4J_PASSWORD": "${NEO4J_PASSWORD}",
        "PROMOTION_MODE": "soc2",
        "AUTO_APPROVAL_THRESHOLD": "0.85"
      }
    }
  }
}
