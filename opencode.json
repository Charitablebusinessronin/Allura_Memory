{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "openwork",
  "mcp": {
    "allura-brain": {
      "enabled": true,
      "oauth": false,
      "type": "remote",
      "url": "http://localhost:5888/mcp"
    },
    "chrome-devtools": {
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "type": "local"
    }
  },
  "model": "ollama-cloud/glm-5.1",
  "plugin": [
    "opencode-scheduler"
  ]
}
