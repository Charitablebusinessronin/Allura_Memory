{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "MCP_DOCKER": {
      "type": "local",
      "command": ["docker", "mcp", "gateway", "run"],
      "enabled": true
    },
    "neo4j": {
      "type": "local",
      "command": ["docker", "run", "-i", "--rm",
        "--network", "roninmemory_default",
        "-e", "NEO4J_URI",
        "-e", "NEO4J_USERNAME",
        "-e", "NEO4J_PASSWORD",
        "-e", "NEO4J_DATABASE",
        "mcp/neo4j"
      ],
      "env": {
        "NEO4J_URI": "bolt://knowledge-neo4j:7687",
        "NEO4J_USERNAME": "${NEO4J_USER}",
        "NEO4J_PASSWORD": "${NEO4J_PASSWORD}",
        "NEO4J_DATABASE": "neo4j"
      },
      "enabled": true
    },
    "postgres": {
      "type": "local",
      "command": ["docker", "run", "-i", "--rm",
        "--network", "roninmemory_default",
        "-e", "DATABASE_URL",
        "mcp/postgres"
      ],
      "env": {
        "DATABASE_URL": "postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@knowledge-postgres:5432/${POSTGRES_DB}"
      },
      "enabled": true
    },
    "notion": {
      "type": "local",
      "command": ["docker", "run", "-i", "--rm",
        "-e", "NOTION_API_TOKEN",
        "mcp/notion"
      ],
      "env": {
        "NOTION_API_TOKEN": "${NOTION_API_TOKEN}"
      },
      "enabled": true
    },
    "tavily": {
      "type": "local",
      "command": ["docker", "run", "-i", "--rm",
        "-e", "TAVILY_API_KEY",
        "mcp/tavily"
      ],
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      },
      "enabled": true
    },
    "github": {
      "type": "local",
      "command": ["docker", "run", "-i", "--rm",
        "-e", "GITHUB_PERSONAL_ACCESS_TOKEN",
        "mcp/github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      },
      "enabled": true
    },
    "filesystem": {
      "type": "local",
      "command": ["docker", "run", "-i", "--rm",
        "-v", "${PWD}:/workspace",
        "mcp/filesystem",
        "/workspace"
      ],
      "enabled": true
    },
    "docker": {
      "type": "local",
      "command": ["docker", "run", "-i", "--rm",
        "-v", "/var/run/docker.sock:/var/run/docker.sock",
        "mcp/docker"
      ],
      "enabled": true
    }
  },
  "agents": ".opencode/agents",
  "skills": ".opencode/skills"
}
