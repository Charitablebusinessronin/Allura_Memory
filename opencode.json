{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "experimentalAgentTeams": true,
  "terminals": "tmux",
  "mcpServers": {
    "allura-brain": {
      "command": "bun",
      "args": ["run", "src/mcp/memory-server-canonical.ts"],
      "env": {
        "POSTGRES_HOST": "localhost",
        "POSTGRES_PORT": "5432",
        "POSTGRES_DB": "memory",
        "POSTGRES_USER": "ronin4life",
        "POSTGRES_PASSWORD": "${POSTGRES_PASSWORD}",
        "NEO4J_URI": "bolt://localhost:7687",
        "NEO4J_USER": "neo4j",
        "NEO4J_PASSWORD": "${NEO4J_PASSWORD}",
        "RUVECTOR_HOST": "localhost",
        "RUVECTOR_PORT": "5432",
        "RUVECTOR_USER": "ronin4life",
        "RUVECTOR_PASSWORD": "${POSTGRES_PASSWORD}",
        "RUVECTOR_DB": "memory",
        "GRAPH_BACKEND": "neo4j",
        "DEFAULT_GROUP_ID": "allura-roninmemory",
        "PROMOTION_MODE": "soc2",
        "AUTO_APPROVAL_THRESHOLD": "0.85"
      }
    },
    "neo4j-cypher": {
      "command": "docker",
      "args": [
        "run", "-i", "--rm",
        "-e", "NEO4J_URL",
        "-e", "NEO4J_USERNAME",
        "-e", "NEO4J_DATABASE",
        "-e", "NEO4J_PASSWORD",
        "-e", "NEO4J_READ_ONLY",
        "-e", "NEO4J_READ_TIMEOUT",
        "-e", "NEO4J_RESPONSE_TOKEN_LIMIT",
        "-e", "NEO4J_SCHEMA_SAMPLE_SIZE",
        "mcp/neo4j-cypher"
      ],
      "env": {
        "NEO4J_URL": "bolt://host.docker.internal:7687",
        "NEO4J_USERNAME": "neo4j",
        "NEO4J_DATABASE": "neo4j",
        "NEO4J_PASSWORD": "${NEO4J_PASSWORD}",
        "NEO4J_READ_ONLY": "false",
        "NEO4J_READ_TIMEOUT": "30",
        "NEO4J_RESPONSE_TOKEN_LIMIT": "10000",
        "NEO4J_SCHEMA_SAMPLE_SIZE": "1000"
      }
    },
    "neo4j-memory": {
      "command": "docker",
      "args": [
        "run", "-i", "--rm",
        "-e", "NEO4J_URL",
        "-e", "NEO4J_USERNAME",
        "-e", "NEO4J_DATABASE",
        "-e", "NEO4J_PASSWORD",
        "mcp/neo4j-memory"
      ],
      "env": {
        "NEO4J_URL": "bolt://host.docker.internal:7687",
        "NEO4J_USERNAME": "neo4j",
        "NEO4J_DATABASE": "neo4j",
        "NEO4J_PASSWORD": "${NEO4J_PASSWORD}"
      }
    }
  },
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "webfetch": "allow",
    "bash": "ask",
    "edit": "ask",
    "write": "ask",
    "skill": {
      "allura-menu": "allow",
      "bun-security": "allow",
      "code-review": "allow",
      "github": "allow",
      "hitl-governance": "allow",
      "mcp-builder": "allow",
      "mcp-docker": "allow",
      "mcp-docker-memory-system": "allow",
      "memory-client": "allow",
      "context7": "allow",
      "multi-search": "allow",
      "next-best-practices": "allow",
      "party-mode": "allow",
      "postgres-best-practices": "allow",
      "quick-update": "allow",
      "readme-memory": "allow",
      "skill-creator": "allow",
      "superpowers-memory": "allow",
      "systematic-debugging-memory": "allow",
      "task-creator": "allow",
      "task-management": "allow",
      "trailofbits-audit": "allow"
    }
  },
  "instructions": [
    ".opencode/AGENTS.md",
    ".opencode/rules/_bootstrap.md",
    ".opencode/rules/agent-routing.md",
    ".opencode/rules/mcp-integration.md",
    ".opencode/rules/AI-GUIDELINES.md"
  ],
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  }
}
