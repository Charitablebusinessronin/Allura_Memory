{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@gotgenes/opencode-agent-identity",
    "superpowers@git+https://github.com/obra/superpowers.git",
    "./plugin/group-id-enforcer.ts"
  ],
  "default_agent": "memory-builder-auto",
  "instructions": [
    "AGENTS.md",
    ".github/copilot-instructions.md",
    ".opencode/context/project/bmad-integration.md"
  ],
  "agent": {
    "memory-orchestrator": {
      "description": "Primary OpenCode agent for allura-memory development with memory-first workflow, BMad routing, and Bun-only security.",
      "mode": "primary",
      "model": "ollama-cloud/glm-5",
      "prompt": "{file:.opencode/agent/core/openagent.md}",
      "temperature": 0.2,
      "color": "accent",
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow"
        },
        "skill": {
          "*": "allow"
        }
      }
    },
    "memory-architect": {
      "description": "Architecture-focused OpenCode agent for allura-memory implementation design, BMad workflow selection, and complex solution shaping.",
      "mode": "primary",
      "model": "ollama-cloud/glm-5",
      "prompt": "{file:.opencode/agent/core/opencoder.md}",
      "temperature": 0.1,
      "color": "info",
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow"
        },
        "skill": {
          "*": "allow"
        }
      }
    },
    "memory-builder": {
      "description": "Implementation-focused OpenCode agent for allura-memory code construction, pattern application, and self-review.",
      "mode": "primary",
      "model": "ollama-cloud/kimi-k2.5",
      "prompt": "{file:.opencode/agent/core/coder.md}",
      "temperature": 0.1,
      "color": "success",
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow"
        },
        "skill": {
          "*": "allow"
        }
      }
    },
    "memory-guardian": {
      "description": "Code review and security-focused OpenCode agent for allura-memory quality gates and pattern validation.",
      "mode": "primary",
      "model": "ollama-cloud/glm-5",
      "prompt": "{file:.opencode/agent/core/reviewer.md}",
      "temperature": 0.05,
      "color": "warning",
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow"
        },
        "skill": {
          "*": "allow"
        }
      }
    },
    "memory-scout": {
      "description": "Context discovery-focused OpenCode agent for allura-memory pattern finding and standards lookup.",
      "mode": "primary",
      "model": "ollama-cloud/ministral-3:8b",
      "prompt": "{file:.opencode/agent/core/contextscout.md}",
      "temperature": 0.1,
      "color": "secondary",
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow"
        },
        "skill": {
          "*": "allow"
        }
      }
    },
    "memory-chronicler": {
      "description": "Documentation-focused OpenCode agent for allura-memory knowledge capture and technical writing.",
      "mode": "primary",
      "model": "ollama-cloud/glm-5",
      "prompt": "{file:.opencode/agent/core/documentation.md}",
      "temperature": 0.3,
      "color": "info",
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow"
        },
        "skill": {
          "*": "allow"
        }
      }
    },
    "memory-builder-focus": {
      "description": "FOCUS MODE - Elevated permissions for intensive development flow state. Auto-elevated bash, edit, write permissions with critical safety guards.",
      "mode": "primary",
      "model": "ollama-cloud/kimi-k2.5",
      "prompt": "{file:.opencode/agent/memory-builder-focus.md}",
      "temperature": 0.1,
      "color": "warning",
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow",
          "rm -rf *": "ask",
          "rm -rf /*": "deny",
          "sudo *": "deny",
          "> /dev/*": "deny",
          "chmod 777 *": "ask"
        },
        "skill": {
          "*": "allow"
        }
      }
    },
    "roninmemory-project": {
      "description": "Compatibility alias for MemoryOrchestrator while existing allura-memory references are migrated.",
      "mode": "primary",
      "model": "ollama-cloud/glm-5",
      "prompt": "{file:.opencode/agent/core/openagent.md}",
      "temperature": 0.2,
      "color": "accent",
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow"
        },
        "skill": {
          "*": "allow"
        }
      }
    },
    "memory-builder-auto": {
      "description": "FULLY AUTONOMOUS MODE - Zero permission prompts. Auto-executes all bash, edit, write operations. Never stops for approval. Logs all actions to memory.",
      "mode": "primary",
      "model": "ollama-cloud/kimi-k2.5",
      "prompt": "{file:.opencode/agent/core/memory-builder-auto.md}",
      "temperature": 0.1,
      "color": "#dc2626",
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow"
        },
        "skill": {
          "*": "allow"
        }
      }
    }
  },
  "mcp": {
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?exaApiKey=44a9fc3d-0334-4822-97a4-5c2a53f4c270",
      "enabled": true
    }
  },
  "skills": {
    "directories": [
      ".opencode/skills"
    ]
  }
}
