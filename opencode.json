{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "mcp": {
    "allura-brain": {
      "type": "local",
      "command": ["docker", "exec", "-i", "allura-memory-mcp", "bun", "src/mcp/memory-server-canonical.ts"]
    }
  },
  "permission": {
    "*": "allow",
    "edit": "allow",
    "bash": "allow",
    "write": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "webfetch": "allow",
    "skill": {
      "allura-menu": "allow",
      "bun-security": "allow",
      "code-review": "allow",
      "github": "allow",
      "hitl-governance": "allow",
      "mcp-builder": "allow",
      "mcp-docker": "allow",
      "mcp-docker-memory-system": "allow",
      "memory-client": "allow",
      "context7": "allow",
      "multi-search": "allow",
      "next-best-practices": "allow",
      "party-mode": "allow",
      "postgres-best-practices": "allow",
      "quick-update": "allow",
      "readme-memory": "allow",
      "skill-creator": "allow",
      "superpowers-memory": "allow",
      "systematic-debugging-memory": "allow",
      "task-creator": "allow",
      "task-management": "allow",
      "trailofbits-audit": "allow"
    }
  },
  "instructions": [
    ".opencode/AGENTS.md",
    ".opencode/rules/_bootstrap.md",
    ".opencode/rules/agent-routing.md",
    ".opencode/rules/mcp-integration.md",
    ".opencode/rules/AI-GUIDELINES.md"
  ],
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  }
}
