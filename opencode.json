{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "MCP_DOCKER": {
      "type": "local",
      "command": ["docker", "mcp", "gateway", "run"],
      "enabled": true
    },
    "neo4j": {
      "type": "local",
      "command": ["docker", "run", "-i", "--rm",
        "--network", "roninmemory_default",
        "-e", "NEO4J_URI",
        "-e", "NEO4J_USERNAME",
        "-e", "NEO4J_PASSWORD",
        "-e", "NEO4J_DATABASE",
        "mcp/neo4j"
      ],
      "environment": {
        "NEO4J_URI": "bolt://knowledge-neo4j:7687",
        "NEO4J_USERNAME": "${NEO4J_USER}",
        "NEO4J_PASSWORD": "${NEO4J_PASSWORD}",
        "NEO4J_DATABASE": "neo4j"
      },
      "enabled": true
    },
    "postgres": {
      "type": "local",
      "command": ["docker", "run", "-i", "--rm",
        "--network", "roninmemory_default",
        "-e", "DATABASE_URL",
        "mcp/postgres"
      ],
      "environment": {
        "DATABASE_URL": "postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@knowledge-postgres:5432/${POSTGRES_DB}"
      },
      "enabled": true
    },
    "notion": {
      "type": "local",
      "command": ["docker", "run", "-i", "--rm",
        "-e", "NOTION_TOKEN",
        "mcp/notion"
      ],
      "environment": {
        "NOTION_TOKEN": "${NOTION_TOKEN}"
      },
      "enabled": true
    },
    "tavily": {
      "type": "local",
      "command": ["docker", "run", "-i", "--rm",
        "-e", "TAVILY_API_KEY",
        "mcp/tavily"
      ],
      "environment": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      },
      "enabled": true
    },
    "ollama": {
      "type": "local",
      "command": ["docker", "run", "-i", "--rm",
        "--network", "host",
        "-e", "OLLAMA_HOST",
        "mcp/ollama"
      ],
      "environment": {
        "OLLAMA_HOST": "${OLLAMA_HOST:-http://localhost:11434}"
      },
      "enabled": true
    },
    "filesystem": {
      "type": "local",
      "command": ["docker", "run", "-i", "--rm",
        "-v", "${PWD}:/workspace",
        "mcp/filesystem",
        "/workspace"
      ],
      "enabled": true
    },
    "docker": {
      "type": "local",
      "command": ["docker", "run", "-i", "--rm",
        "-v", "/var/run/docker.sock:/var/run/docker.sock",
        "mcp/docker"
      ],
      "enabled": true
    },
    "ronin-memory": {
      "type": "local",
      "command": ["docker", "run", "-i", "--rm",
        "--network", "roninmemory_default",
        "-v", "${PWD}:/app",
        "-w", "/app",
        "-e", "NEO4J_URI=bolt://knowledge-neo4j:7687",
        "-e", "NEO4J_USER=${NEO4J_USER}",
        "-e", "NEO4J_PASSWORD=${NEO4J_PASSWORD}",
        "-e", "POSTGRES_HOST=knowledge-postgres",
        "-e", "POSTGRES_PORT=5432",
        "-e", "POSTGRES_DB=${POSTGRES_DB}",
        "-e", "POSTGRES_USER=${POSTGRES_USER}",
        "-e", "POSTGRES_PASSWORD=${POSTGRES_PASSWORD}",
        "node:20-alpine",
        "npx", "tsx", "src/mcp/memory-server.ts"
      ],
      "enabled": true
    }
  },
  "skills": {
    "paths": [".opencode/skills"]
  }
}
