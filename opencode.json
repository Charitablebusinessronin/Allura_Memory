{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "MCP_DOCKER": {
      "type": "local",
      "command": ["docker", "mcp", "gateway", "run"],
      "enabled": true
    },
    "ronin-memory": {
      "type": "local",
      "command": ["docker", "exec", "-i", "knowledge-mcp", "node", "dist/mcp/memory-server.js"],
      "enabled": true
    }
  },
  "agents": ".opencode/agents",
  "skills": ".opencode/skills"
}
