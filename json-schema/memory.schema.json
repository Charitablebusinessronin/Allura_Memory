{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://allura.dev/schemas/memory.schema.json",
  "title": "Memory",
  "description": "Curated, promoted knowledge node in Neo4j",
  "type": "object",
  "required": [
    "id", "name", "group_id", "category", "type", "confidence",
    "content", "source", "status", "score", "deprecated", "created_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier. Generated at promotion time."
    },
    "name": {
      "type": "string",
      "description": "Short descriptive title for the memory"
    },
    "group_id": {
      "type": "string",
      "pattern": "^allura-[a-z0-9-]+$",
      "description": "Tenant namespace"
    },
    "category": {
      "type": "string",
      "enum": [
        "decision", "pattern", "rule", "fact", "lesson",
        "insight", "preference", "standard"
      ],
      "description": "Memory classification"
    },
    "type": {
      "type": "string",
      "enum": ["procedural", "declarative", "strategic", "operational"],
      "description": "Memory type"
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Confidence score (0.0–1.0)"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Freeform tags for retrieval filtering"
    },
    "content": {
      "type": "string",
      "description": "The memory text"
    },
    "source": {
      "type": "string",
      "enum": ["notion", "curator", "manual", "conversation"],
      "description": "Origin of the memory"
    },
    "notion_id": {
      "type": "string",
      "description": "Notion page ID for bidirectional traceability"
    },
    "status": {
      "type": "string",
      "enum": ["active", "deprecated", "pending"],
      "description": "Node lifecycle status"
    },
    "score": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Confidence/relevance score (0.0–1.0)"
    },
    "deprecated": {
      "type": "boolean",
      "default": false,
      "description": "True when a newer version supersedes this node"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "UTC timestamp of node creation"
    },
    "source_event_id": {
      "type": "string",
      "description": "ID of the originating events row in Postgres"
    },
    "purpose": {
      "type": "string",
      "description": "Intended use of the memory"
    },
    "core_structure": {
      "type": "string",
      "description": "Structural template or pattern the memory follows"
    },
    "knowledge_rules": {
      "type": "string",
      "description": "Rules governing how this memory should be used"
    }
  },
  "additionalProperties": false
}
