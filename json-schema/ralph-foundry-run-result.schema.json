{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://allura.dev/schemas/ralph-foundry-run-result.schema.json",
  "title": "RalphFoundryRunResult",
  "description": "Terminal result of a Ralph Foundry run. Lifecycle belongs in the append-only run log.",
  "type": "object",
  "required": ["runId", "status", "summary", "schemaVersion", "breakingChangePolicy"],
  "properties": {
    "runId": { "type": "string", "pattern": "^rf-[0-9]+$", "description": "References RalphFoundryRunManifest.runId." },
    "status": { "type": "string", "enum": ["executed", "failed", "blocked", "cancelled"], "description": "Terminal status only." },
    "summary": { "type": "string", "minLength": 1, "description": "Human-readable outcome summary or blocker/cancel reason." },
    "evidence": { "type": "array", "items": { "type": "string", "minLength": 1 }, "description": "Required for executed and failed; optional for blocked and cancelled." },
    "completedAt": { "type": "string", "format": "date-time" },
    "schemaVersion": { "type": "string", "const": "0.1.0" },
    "breakingChangePolicy": { "type": "string", "const": "Only patch-level bumps are non-breaking; minor bumps require a migration step." },
    "deprecationDate": { "type": "string", "format": "date" }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "enum": ["executed", "failed"] } }, "required": ["status"] },
      "then": { "required": ["evidence"], "properties": { "evidence": { "type": "array", "minItems": 1 } } }
    }
  ],
  "additionalProperties": false
}
