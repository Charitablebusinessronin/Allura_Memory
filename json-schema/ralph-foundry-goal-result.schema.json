{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://allura.dev/schemas/ralph-foundry-goal-result.schema.json",
  "title": "RalphFoundryGoalResult",
  "description": "Terminal result of a Team-Gated Autonomous Ralph Foundry goal loop.",
  "type": "object",
  "required": ["goalId", "status", "summary", "totalRuns", "runIds", "schemaVersion", "breakingChangePolicy"],
  "properties": {
    "goalId": { "type": "string", "pattern": "^rfg-[0-9]+$", "description": "References RalphFoundryGoalManifest.goalId." },
    "status": { "type": "string", "enum": ["achieved", "failed", "escalated", "abandoned"], "description": "Terminal goal status only." },
    "summary": { "type": "string", "minLength": 1, "description": "Human-readable outcome summary or escalation reason." },
    "totalRuns": { "type": "integer", "minimum": 0, "description": "Number of bounded Ralph Foundry runs attempted under this goal." },
    "runIds": { "type": "array", "items": { "type": "string", "pattern": "^rf-[0-9]+$" }, "description": "Run artifacts produced under this goal." },
    "stopConditionHit": {
      "type": "string",
      "enum": [
        "goal-achieved",
        "max-runs-reached",
        "same-validation-failure-twice",
        "three-failed-fixes-same-issue",
        "blocked-path-touched",
        "secret-or-destructive-action-required",
        "deploy-action-required",
        "architecture-decision-required",
        "validation-unavailable",
        "success-criteria-not-objective"
      ],
      "description": "Stop condition that ended the loop."
    },
    "evidence": { "type": "array", "items": { "type": "string", "minLength": 1 }, "description": "Required for achieved, failed, and escalated; optional for abandoned." },
    "learningRefs": { "type": "array", "items": { "type": "string", "minLength": 1 }, "description": "References to Allura Brain memories or local learning artifacts written during the loop." },
    "completedAt": { "type": "string", "format": "date-time" },
    "schemaVersion": { "type": "string", "const": "0.1.0" },
    "breakingChangePolicy": { "type": "string", "const": "Only patch-level bumps are non-breaking; minor bumps require a migration step." },
    "deprecationDate": { "type": "string", "format": "date" }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "enum": ["achieved", "failed", "escalated"] } }, "required": ["status"] },
      "then": { "required": ["evidence", "stopConditionHit"], "properties": { "evidence": { "type": "array", "minItems": 1 } } }
    }
  ],
  "additionalProperties": false
}
