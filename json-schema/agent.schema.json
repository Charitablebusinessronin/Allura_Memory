{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://allura.dev/schemas/agent.schema.json",
  "title": "Agent",
  "description": "AI agent node in Neo4j",
  "type": "object",
  "required": [
    "id", "name", "persona", "team", "category", "type",
    "scope", "platform", "status", "group_id"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique agent identifier (e.g. brooks, pike)"
    },
    "name": {
      "type": "string",
      "description": "Human-readable agent name"
    },
    "persona": {
      "type": "string",
      "description": "Agent persona description"
    },
    "team": {
      "type": "string",
      "description": "Team name this agent belongs to"
    },
    "category": {
      "type": "string",
      "enum": ["ram", "durham", "governance", "ship"],
      "description": "Agent classification"
    },
    "type": {
      "type": "string",
      "enum": [
        "executor", "reviewer", "curator", "orchestrator",
        "specialist", "creative"
      ],
      "description": "Agent type"
    },
    "scope": {
      "type": "string",
      "enum": ["project", "team", "global"],
      "description": "Operational scope"
    },
    "platform": {
      "type": "string",
      "enum": ["openclaw", "claude", "cursor", "opencode"],
      "description": "Platform this agent runs on"
    },
    "status": {
      "type": "string",
      "enum": ["active", "inactive", "retired"],
      "description": "Agent lifecycle status"
    },
    "group_id": {
      "type": "string",
      "pattern": "^allura-[a-z0-9-]+$",
      "description": "Tenant namespace"
    },
    "description": {
      "type": "string",
      "description": "Extended description of the agent's role"
    }
  },
  "additionalProperties": false
}
