{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://allura.dev/schemas/team.schema.json",
  "title": "Team",
  "description": "Team of agents node in Neo4j",
  "type": "object",
  "required": ["id", "name", "group_id"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique team identifier (e.g. ram, durham)"
    },
    "name": {
      "type": "string",
      "description": "Human-readable team name"
    },
    "group_id": {
      "type": "string",
      "pattern": "^allura-[a-z0-9-]+$",
      "description": "Tenant namespace"
    },
    "icon": {
      "type": "string",
      "description": "Emoji or icon identifier for the team"
    },
    "description": {
      "type": "string",
      "description": "Team description and purpose"
    }
  },
  "additionalProperties": false
}
