{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://allura.dev/schemas/project.schema.json",
  "title": "Project",
  "description": "Project node in Neo4j",
  "type": "object",
  "required": ["id", "name", "group_id", "status"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique project identifier (e.g. allura-memory)"
    },
    "name": {
      "type": "string",
      "description": "Human-readable project name"
    },
    "group_id": {
      "type": "string",
      "pattern": "^allura-[a-z0-9-]+$",
      "description": "Tenant namespace"
    },
    "status": {
      "type": "string",
      "enum": ["active", "planned", "complete", "on-hold"],
      "description": "Project lifecycle status"
    },
    "description": {
      "type": "string",
      "description": "Project description and scope"
    }
  },
  "additionalProperties": false
}
