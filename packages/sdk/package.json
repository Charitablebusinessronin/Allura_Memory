{
  "name": "@allura/sdk",
  "version": "0.2.0",
  "description": "TypeScript SDK for Allura Memory — dual-transport client for MCP Streamable HTTP and legacy JSON-RPC",
  "keywords": [
    "allura",
    "memory",
    "mcp",
    "sdk",
    "ai",
    "knowledge-graph"
  ],
  "author": "Allura Memory Team",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "bump-version": "bun run scripts/bump-version.ts",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  },
  "peerDependencies": {},
  "repository": {
    "type": "git",
    "url": "https://github.com/Charitablebusinessronin/Allura_Memory.git",
    "directory": "packages/sdk"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
