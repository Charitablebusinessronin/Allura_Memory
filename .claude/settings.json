{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(.claude/**)",
      "Edit(.claude/**)",
      "Write(.claude/**)",
      "Bash(bun run *)",
      "Bash(bun install)",
      "Bash(bun*)",
      "Bash(cp *)",
      "Bash(bun test)",
      "Bash(git *)",
      "Bash(docker *)",
      "Bash(gh *)",
      "Bash(npm run *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(mkdir *)",
      "Bash(mv *)",
      "Bash(rm -rf .tmp/*)",
      "Bash(rm -rf node_modules/.cache/*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf .env*)",
      "Bash(cat .env*)",
      "Bash(*secrets*)",
      "Bash(*password*)",
      "Bash(*token*)",
      "Bash(curl *localhost*)",
      "Bash(wget *localhost*)"
    ],
    "additionalDirectories": []
  },
  "experimentalAgentTeams": true,
  "terminals": "tmux",
  "mcpServers": {
    "allura-brain": {
      "command": "bun",
      "args": ["run", "src/mcp/memory-server-canonical.ts"],
      "env": {
        "POSTGRES_HOST": "localhost",
        "POSTGRES_PORT": "5432",
        "POSTGRES_DB": "memory",
        "POSTGRES_USER": "ronin4life",
        "POSTGRES_PASSWORD": "${POSTGRES_PASSWORD}",
        "NEO4J_URI": "bolt://localhost:7687",
        "NEO4J_USER": "neo4j",
        "NEO4J_PASSWORD": "${NEO4J_PASSWORD}",
        "RUVECTOR_HOST": "localhost",
        "RUVECTOR_PORT": "5432",
        "RUVECTOR_USER": "ronin4life",
        "RUVECTOR_PASSWORD": "${POSTGRES_PASSWORD}",
        "RUVECTOR_DB": "memory",
        "GRAPH_BACKEND": "neo4j",
        "DEFAULT_GROUP_ID": "allura-roninmemory",
        "PROMOTION_MODE": "soc2",
        "AUTO_APPROVAL_THRESHOLD": "0.85"
      }
    },
    "neo4j-cypher": {
      "command": "docker",
      "args": [
        "run", "-i", "--rm",
        "-e", "NEO4J_URL",
        "-e", "NEO4J_USERNAME",
        "-e", "NEO4J_DATABASE",
        "-e", "NEO4J_PASSWORD",
        "-e", "NEO4J_READ_ONLY",
        "-e", "NEO4J_READ_TIMEOUT",
        "-e", "NEO4J_RESPONSE_TOKEN_LIMIT",
        "-e", "NEO4J_SCHEMA_SAMPLE_SIZE",
        "mcp/neo4j-cypher"
      ],
      "env": {
        "NEO4J_URL": "bolt://host.docker.internal:7687",
        "NEO4J_USERNAME": "neo4j",
        "NEO4J_DATABASE": "neo4j",
        "NEO4J_PASSWORD": "${NEO4J_PASSWORD}",
        "NEO4J_READ_ONLY": "false",
        "NEO4J_READ_TIMEOUT": "30",
        "NEO4J_RESPONSE_TOKEN_LIMIT": "10000",
        "NEO4J_SCHEMA_SAMPLE_SIZE": "1000"
      }
    },
    "neo4j-memory": {
      "command": "docker",
      "args": [
        "run", "-i", "--rm",
        "-e", "NEO4J_URL",
        "-e", "NEO4J_USERNAME",
        "-e", "NEO4J_DATABASE",
        "-e", "NEO4J_PASSWORD",
        "mcp/neo4j-memory"
      ],
      "env": {
        "NEO4J_URL": "bolt://host.docker.internal:7687",
        "NEO4J_USERNAME": "neo4j",
        "NEO4J_DATABASE": "neo4j",
        "NEO4J_PASSWORD": "${NEO4J_PASSWORD}"
      }
    }
  },
  "commands": {
    "mcp-discover": {
      "source": ".claude/commands/mcp-discover.md",
      "description": "Discover available MCP servers"
    },
    "mcp-approve": {
      "source": ".claude/commands/mcp-approve.md",
      "description": "Request MCP server approval"
    },
    "mcp-load": {
      "source": ".claude/commands/mcp-load.md",
      "description": "Load an approved MCP server"
    },
    "skill-propose": {
      "source": ".claude/commands/skill-propose.md",
      "description": "Propose a skill and show executor"
    },
    "skill-load": {
      "source": ".claude/commands/skill-load.md",
      "description": "Execute a skill with routing"
    },
    "harness-status": {
      "source": ".claude/commands/harness-status.md",
      "description": "Show harness health and loaded servers"
    }
  },
  "qr": {
    "currentQR": null
  }
}
