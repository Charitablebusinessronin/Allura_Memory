# Roninmemory Environment Variables Template
# Copy this to .env.local and fill in real values
# DO NOT commit .env.local with real credentials

# =============================================================================
# RuVix Kernel (Layer 1 - Proof-gated mutation)
# =============================================================================
# Required: 32+ character secret for HMAC-SHA256 proof-of-intent
# Generate with: openssl rand -base64 32
RUVIX_KERNEL_SECRET=your_kernel_secret_key_here_min_32_chars_long_for_hmac_sha256

# =============================================================================
# PostgreSQL (Raw Traces)
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=memory
POSTGRES_USER=ronin4life
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_POOL_MAX=10

# =============================================================================
# Neo4j (Promoted Insights)
# =============================================================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_HEAP_INITIAL=512m
NEO4J_HEAP_MAX=2G
NEO4J_PAGECACHE=1G

# =============================================================================
# Multi-Tenant
# =============================================================================
NEXT_PUBLIC_DEFAULT_GROUP_ID=allura-roninmemory
NEXT_PUBLIC_DEFAULT_USER_ID=load-test-vu-1

# =============================================================================
# Embedding Provider
# =============================================================================
# Options: ollama, openai, voyage
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_BASE_URL=http://localhost:11434

# For OpenAI embeddings:
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_API_KEY=sk-your-key-here

# For Voyage embeddings:
# EMBEDDING_PROVIDER=voyage
# EMBEDDING_MODEL=voyage-3
# VOYAGE_API_KEY=your-voyage-key

# =============================================================================
# LLM Provider (for auto-capture)
# =============================================================================
# Options: ollama, openai, anthropic
OPENCODE_PROVIDER=ollama
OPENCODE_BASE_URL=http://localhost:11434

# Ollama Cloud Models (pull with: ollama pull <model>-cloud)
# Sign in first: ollama signin
OPENCODE_MODEL=ollama-cloud/glm-5.1

# Agent-specific models (used in opencode.json)
# Orchestrator/Architect/Intent Gate: ollama-cloud/gpt-5.4 (highest judgment)
# Builder: ollama-cloud/gpt-5.4-mini (worker default, qwen3-coder-next:cloud for codegen)
# Scout: ollama-cloud/nemotron-3-super:cloud (fast wide-context, gpt-5.4-nano for tiny)
# Fallback (all agents): ollama-cloud/glm-5.1

# For OpenAI:
# OPENCODE_PROVIDER=openai
# OPENCODE_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-your-key-here

# For Anthropic:
# OPENCODE_PROVIDER=anthropic
# OPENCODE_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_API_KEY=your-anthropic-key

# =============================================================================
# Auto-Capture
# =============================================================================
AUTO_CAPTURE_ENABLED=true
AUTO_CAPTURE_LANGUAGE=auto

# =============================================================================
# User Profile Learning
# =============================================================================
USER_PROFILE_ANALYSIS_INTERVAL=10
PROFILE_LEARNING_ENABLED=true

# =============================================================================
# Similarity & Search
# =============================================================================
SIMILARITY_THRESHOLD=0.75

# =============================================================================
# Web UI
# =============================================================================
WEB_SERVER_ENABLED=true
WEB_SERVER_PORT=4748

# =============================================================================
# Governance
# =============================================================================
AUTO_PROMOTE_ENABLED=false
CURATOR_AGENT_ENABLED=true

# Promotion mode: "soc2" (default) requires human approval before Neo4j write.
# "auto" promotes immediately when score >= AUTO_APPROVAL_THRESHOLD.
# CLI flag --auto-approve-threshold overrides this per run.
PROMOTION_MODE=soc2
AUTO_APPROVAL_THRESHOLD=0.85

# =============================================================================
# Retention (days)
# =============================================================================
TRACE_RETENTION_DAYS=365
INSIGHT_RETENTION_DAYS=0

# =============================================================================
# Ollama LLM
# =============================================================================
OLLAMA_API_KEY=your_ollama_api_key_here
OLLAMA_CLOUD_URL=https://ollama.com

# =============================================================================
# Mission Control
# =============================================================================
MISSION_CONTROL_API_URL=http://localhost:5002
MISSION_CONTROL_TOKEN=your_mission_control_token_here

# =============================================================================
# Notion Integration (remote MCP — no API key, no local service)
# All Notion access via mcp__claude_ai_Notion__* tools. Auth handled by remote MCP.
# =============================================================================
NOTION_DATABASE_ID=your_notion_database_id_here

# =============================================================================
# Smithery CLI
# =============================================================================
SMITHERY_CONFIG=your_smithery_config_here

# =============================================================================
# RuVector (High Performance Vector DB with GNN)
# =============================================================================
# RuVector extends PostgreSQL with vector similarity, GNN, and self-learning
# https://github.com/Charitablebusinessronin/RuVector
RUVECTOR_ENABLED=true
RUVECTOR_HOST=localhost
RUVECTOR_PORT=5433
RUVECTOR_USER=${POSTGRES_USER:-ruvector}
RUVECTOR_PASSWORD=${POSTGRES_PASSWORD:-ruvector}
RUVECTOR_DB=${POSTGRES_DB:-ruvector_test}

# RuVector features:
# - 143 SQL functions for vector operations
# - HNSW progressive indexing
# - Graph Neural Network integration
# - Real-time self-learning
# - Fractional Kelly for optimal sizing
# - LSTM-Transformer for temporal prediction

# =============================================================================
# Enterprise Observability (Docker Compose Enterprise)
# =============================================================================
# Based on: https://github.com/blazity/next-enterprise
# Enable with: docker compose -f docker-compose.yml -f docker-compose.enterprise.yml up -d

# OpenTelemetry
OTEL_SERVICE_NAME=allura-memory
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# Prometheus
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_ENABLED=true
GRAFANA_PORT=3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Redis (Session & Caching)
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis

# Nginx (Reverse Proxy)
NGINX_ENABLED=true
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Paperclip Port (used by Next.js app)
PAPERCLIP_PORT=3100

# Canonical MCP HTTP Gateway Port
ALLURA_MCP_HTTP_PORT=3201

# Legacy OpenClaw Gateway Port (deprecated)
OPENCLAW_PORT=3200
