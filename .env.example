# Allura Memory — Environment Variables Template
# Copy this to .env and fill in real values.
# DO NOT commit .env with real credentials.

# =============================================================================
# PostgreSQL (Episodic Store — required)
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=allura
POSTGRES_USER=allura
POSTGRES_PASSWORD=<required — no default>
POSTGRES_POOL_MAX=10

# =============================================================================
# Neo4j (Semantic Store — required)
# =============================================================================
NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=<required — no default>
NEO4J_DATABASE=neo4j

# =============================================================================
# Governance (required for promotion)
# =============================================================================
# Promotion mode: "soc2" (human-gated review) or "auto" (auto-promote at threshold)
PROMOTION_MODE=soc2
AUTO_APPROVAL_THRESHOLD=0.85

# =============================================================================
# Security (required for production)
# =============================================================================
JWT_SECRET=$(openssl rand -base64 32)
ENCRYPTION_KEY=$(openssl rand -hex 32)

# =============================================================================
# Embeddings (required for vector search)
# =============================================================================
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=qwen3-embedding:8b
EMBEDDING_BASE_URL=http://localhost:11434

# Alternative: OpenAI
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_API_KEY=sk-your-key

# Alternative: Voyage
# EMBEDDING_PROVIDER=voyage
# EMBEDDING_MODEL=voyage-3
# VOYAGE_API_KEY=your-voyage-key

# =============================================================================
# MCP HTTP Gateway (optional — defaults shown)
# =============================================================================
ALLURA_MCP_HTTP_PORT=3201

# =============================================================================
# Web UI (optional — defaults shown)
# =============================================================================
# WEB_SERVER_ENABLED=true
# WEB_SERVER_PORT=3100

# =============================================================================
# Multi-Tenant Defaults (development only)
# =============================================================================
NEXT_PUBLIC_DEFAULT_GROUP_ID=allura-system
NEXT_PUBLIC_DEFAULT_USER_ID=dev-user

# =============================================================================
# Curator (optional — defaults shown)
# =============================================================================
# AUTO_PROMOTE_ENABLED=false
# CURATOR_AGENT_ENABLED=true

# =============================================================================
# Retention (days — optional, defaults shown)
# =============================================================================
# TRACE_RETENTION_DAYS=365
# INSIGHT_RETENTION_DAYS=0

# =============================================================================
# Enterprise / Observability (optional — see docker-compose.enterprise.yml)
# =============================================================================
# OTEL_SERVICE_NAME=allura-memory
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
# REDIS_HOST=localhost
# REDIS_PORT=6379