# Roninmemory Environment Variables Template
# Copy this to .env.local and fill in real values
# DO NOT commit .env.local with real credentials

# =============================================================================
# RuVix Kernel (Layer 1 - Proof-gated mutation)
# =============================================================================
# Required: 32+ character secret for HMAC-SHA256 proof-of-intent
# Generate with: openssl rand -base64 32
RUVIX_KERNEL_SECRET=your_kernel_secret_key_here_min_32_chars_long_for_hmac_sha256

# =============================================================================
# PostgreSQL (Raw Traces)
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=memory
POSTGRES_USER=ronin4life
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_POOL_MAX=10

# =============================================================================
# Neo4j (Promoted Insights)
# =============================================================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_HEAP_INITIAL=512m
NEO4J_HEAP_MAX=2G
NEO4J_PAGECACHE=1G

# =============================================================================
# Multi-Tenant
# =============================================================================
DEFAULT_GROUP_ID=allura-default

# =============================================================================
# Embedding Provider
# =============================================================================
# Options: ollama, openai, voyage
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_BASE_URL=http://localhost:11434

# For OpenAI embeddings:
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_API_KEY=sk-your-key-here

# For Voyage embeddings:
# EMBEDDING_PROVIDER=voyage
# EMBEDDING_MODEL=voyage-3
# VOYAGE_API_KEY=your-voyage-key

# =============================================================================
# LLM Provider (for auto-capture)
# =============================================================================
# Options: ollama, openai, anthropic
OPENCODE_PROVIDER=ollama
OPENCODE_BASE_URL=http://localhost:11434

# Ollama Cloud Models (pull with: ollama pull <model>-cloud)
# Sign in first: ollama signin
OPENCODE_MODEL=glm-5-cloud

# Agent-specific models (used in opencode.json)
# Orchestrator/Architect/Guardian/Chronicler: glm-5-cloud (Agentic: 78.3, Reasoning: 90)
# Builder: kimi-k2.5-cloud (Coding: 70.4)
# Scout: ministral-3:8b-cloud (Fast, 262K context)

# For OpenAI:
# OPENCODE_PROVIDER=openai
# OPENCODE_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-your-key-here

# For Anthropic:
# OPENCODE_PROVIDER=anthropic
# OPENCODE_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_API_KEY=your-anthropic-key

# =============================================================================
# Auto-Capture
# =============================================================================
AUTO_CAPTURE_ENABLED=true
AUTO_CAPTURE_LANGUAGE=auto

# =============================================================================
# User Profile Learning
# =============================================================================
USER_PROFILE_ANALYSIS_INTERVAL=10
PROFILE_LEARNING_ENABLED=true

# =============================================================================
# Similarity & Search
# =============================================================================
SIMILARITY_THRESHOLD=0.75

# =============================================================================
# Web UI
# =============================================================================
WEB_SERVER_ENABLED=true
WEB_SERVER_PORT=4748

# =============================================================================
# Governance
# =============================================================================
AUTO_PROMOTE_ENABLED=false
CURATOR_AGENT_ENABLED=true

# Promotion mode: "soc2" (default) requires human approval before Neo4j write.
# "auto" promotes immediately when score >= AUTO_APPROVAL_THRESHOLD.
# CLI flag --auto-approve-threshold overrides this per run.
PROMOTION_MODE=soc2
AUTO_APPROVAL_THRESHOLD=0.85

# =============================================================================
# Retention (days)
# =============================================================================
TRACE_RETENTION_DAYS=365
INSIGHT_RETENTION_DAYS=0

# =============================================================================
# Ollama LLM
# =============================================================================
OLLAMA_API_KEY=your_ollama_api_key_here
OLLAMA_CLOUD_URL=https://ollama.com

# =============================================================================
# Mission Control
# =============================================================================
MISSION_CONTROL_API_URL=http://localhost:5002
MISSION_CONTROL_TOKEN=your_mission_control_token_here

# =============================================================================
# Notion Integration
# =============================================================================
NOTION_API_KEY=your_notion_api_key_here
NOTION_DATABASE_ID=your_notion_database_id_here
NOTION_API_VERSION=2022-06-28

# =============================================================================
# Smithery CLI
# =============================================================================
SMITHERY_CONFIG=your_smithery_config_here
