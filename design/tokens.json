{
  "$schema": "https://schemas.allura.dev/design-tokens/v1",
  "name": "Allura Memory Dashboard — Semantic Tokens",
  "version": "1.0.0",
  "description": "Semantic design token system for the Allura Memory Dashboard UI. All colors are brand-aligned. IBM Plex Sans is the sole typeface. Use token names, never raw hex, in all downstream specs.",

  "color": {
    "primary": {
      "default": { "value": "#1D4ED8", "type": "color", "description": "Brand blue — CTAs, active nav, primary actions" },
      "hover":   { "value": "#1E40AF", "type": "color", "description": "Darker blue for hover / active states" }
    },
    "secondary": {
      "default": { "value": "#FF5A2E", "type": "color", "description": "Brand orange — Insight markers, highlights, secondary CTAs" },
      "hover":   { "value": "#E04D1F", "type": "color", "description": "Darkened orange for hover state" }
    },
    "success": {
      "default": { "value": "#157A4A", "type": "color", "description": "Positive / confirmation states" },
      "hover":   { "value": "#166534", "type": "color", "description": "Darkened green for hover state" }
    },
    "surface": {
      "default": { "value": "#FFFFFF", "type": "color", "description": "Primary background — cards, panels, modals" },
      "subtle":  { "value": "#F6F4EF", "type": "color", "description": "Cream tint — page background, subtle elevation" },
      "muted":   { "value": "#F3F4F6", "type": "color", "description": "Subtle gray fill — disabled fields, secondary backgrounds" }
    },
    "border": {
      "subtle":  { "value": "#E5E7EB", "type": "color", "description": "Very light borders — dividers, card outlines" },
      "default": { "value": "#D1D5DB", "type": "color", "description": "Standard borders — inputs, table cells" }
    },
    "text": {
      "primary":   { "value": "#0F1115", "type": "color", "description": "Charcoal — headings, primary content" },
      "secondary": { "value": "#6B7280", "type": "color", "description": "Mid-gray — subheadings, secondary text" },
      "muted":     { "value": "#9CA3AF", "type": "color", "description": "Light gray — placeholders, disabled, tertiary info" },
      "inverse":   { "value": "#FFFFFF", "type": "color", "description": "White text on dark or colored backgrounds" }
    },
    "accent": {
      "gold":      { "value": "#C89B3C", "type": "color", "description": "Gold — Project nodes, premium markers, selection rings" },
      "goldHover": { "value": "#A87D2B", "type": "color", "description": "Deeper gold for hover / active accents" },
      "cream":     { "value": "#F6F4EF", "type": "color", "description": "Brand cream — tonal backgrounds, subtle fills" }
    },
    "graph": {
      "agent":    { "value": "{color.primary.default}", "type": "color", "description": "Agent node fill" },
      "project":  { "value": "{color.accent.gold}", "type": "color", "description": "Project node fill" },
      "outcome":  { "value": "{color.success.default}", "type": "color", "description": "Outcome node fill" },
      "event":    { "value": "{color.text.primary}", "type": "color", "description": "Event node fill" },
      "insight":  { "value": "{color.secondary.default}", "type": "color", "description": "Insight node fill" },
      "memory":   { "value": "{color.text.muted}", "type": "color", "description": "Default Memory node fill" },
      "edge":     { "value": "{color.text.muted}", "type": "color", "description": "Default edge stroke" },
      "edgeHover":{ "value": "{color.primary.default}", "type": "color", "description": "Edge stroke on hover" }
    }
  },

  "spacing": {
    "xs":  { "value": "4px",  "type": "dimension", "description": "Micro gaps — icon-to-text, inline padding" },
    "sm":  { "value": "8px",  "type": "dimension", "description": "Tight gaps — tag padding, table cell padding Y" },
    "md":  { "value": "12px", "type": "dimension", "description": "Compact — button padding, form field gaps" },
    "lg":  { "value": "16px", "type": "dimension", "description": "Standard — card padding, section gaps" },
    "xl":  { "value": "24px", "type": "dimension", "description": "Relaxed — panel padding, sidebar sections" },
    "2xl": { "value": "32px", "type": "dimension", "description": "Loose — page margins, major section breaks" },
    "3xl": { "value": "48px", "type": "dimension", "description": "Extra loose — hero areas, empty states" }
  },

  "borderRadius": {
    "sm":  { "value": "4px",  "type": "dimension", "description": "Tags, small badges, tight UI" },
    "md":  { "value": "8px",  "type": "dimension", "description": "Cards, buttons, input fields" },
    "lg":  { "value": "12px", "type": "dimension", "description": "Large cards, modals, elevated panels" },
    "full":{ "value": "9999px","type": "dimension", "description": "Pills, avatars, circular buttons" }
  },

  "shadow": {
    "sm": {
      "value": "0 1px 2px 0 rgba(15, 17, 21, 0.05)",
      "type": "shadow",
      "description": "Subtle elevation — tags, small cards"
    },
    "md": {
      "value": "0 4px 6px -1px rgba(15, 17, 21, 0.1), 0 2px 4px -2px rgba(15, 17, 21, 0.1)",
      "type": "shadow",
      "description": "Card elevation — stat cards, memory rows"
    },
    "lg": {
      "value": "0 10px 15px -3px rgba(15, 17, 21, 0.1), 0 4px 6px -4px rgba(15, 17, 21, 0.1)",
      "type": "shadow",
      "description": "Modal / dropdown elevation — popovers, mobile overlay"
    }
  },

  "typography": {
    "fontFamily": {
      "sans": {
        "value": "'IBM Plex Sans', system-ui, -apple-system, sans-serif",
        "type": "fontFamily",
        "description": "Primary typeface — all UI text"
      }
    },
    "fontWeight": {
      "normal":  { "value": "400", "type": "fontWeight", "description": "Body text, descriptions" },
      "medium":  { "value": "500", "type": "fontWeight", "description": "Labels, emphasized body" },
      "semibold":{ "value": "600", "type": "fontWeight", "description": "Subheadings, button text" },
      "bold":    { "value": "700", "type": "fontWeight", "description": "Page titles, stat numbers, emphasis" }
    },
    "fontSize": {
      "xs":   { "value": "12px", "type": "fontSize", "description": "Captions, timestamps, graph labels" },
      "sm":   { "value": "14px", "type": "fontSize", "description": "Secondary text, table cells, tags" },
      "base": { "value": "16px", "type": "fontSize", "description": "Body text, default UI copy" },
      "lg":   { "value": "18px", "type": "fontSize", "description": "Lead paragraph, card headings" },
      "xl":   { "value": "20px", "type": "fontSize", "description": "Section titles, modal headings" },
      "2xl":  { "value": "24px", "type": "fontSize", "description": "Page H2, stat labels" },
      "3xl":  { "value": "30px", "type": "fontSize", "description": "Page H1 (mobile)" },
      "4xl":  { "value": "36px", "type": "fontSize", "description": "Page H1 (tablet)" },
      "5xl":  { "value": "48px", "type": "fontSize", "description": "Hero numbers, large display" },
      "6xl":  { "value": "56px", "type": "fontSize", "description": "Maximum display size — hero headlines" }
    },
    "lineHeight": {
      "tight": { "value": "1.25", "type": "lineHeight", "description": "Headings, single-line labels" },
      "normal":{ "value": "1.5",  "type": "lineHeight", "description": "Body text, descriptions" },
      "relaxed":{ "value": "1.625","type": "lineHeight", "description": "Long-form reading, raw logs" }
    }
  }
}
