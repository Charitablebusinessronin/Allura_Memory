{
  "name": "allura-memory",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env FORCE_COLOR=1 next dev --turbo -p ${PAPERCLIP_PORT:-3100}",
    "build": "next build",
    "start": "next start -p ${PAPERCLIP_PORT:-3100}",
    "typecheck": "tsc --noEmit",
    "lint:eslint": "next lint",
    "lint:eslint:fix": "next lint --fix",
    "prettier": "prettier --check \"**/*.{js,jsx,ts,tsx}\"",
    "prettier:fix": "prettier --write \"**/*.{js,jsx,ts,tsx}\"",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "analyze": "cross-env ANALYZE=true bun run build",
    "test": "bun vitest run",
    "test:watch": "bun vitest",
    "test:e2e": "RUN_E2E_TESTS=true bun vitest run src/__tests__/e2e-integration.test.ts",
    "test:mcp:browser": "bun scripts/test-mcp-browser.ts",
    "test:mcp:browser:update": "bun scripts/test-mcp-browser.ts --update",
    "test:mcp:browser:verbose": "bun scripts/test-mcp-browser.ts --verbose",
    "test:all": "bun run typecheck && bun run lint && bun test && bun run test:e2e && bun run test:mcp:browser",
    "benchmark": "bun scripts/benchmark.js --events=1000 --batch=100",
    "docs": "bun scripts/generate-docs.js",
    "lint": "bun run typecheck",
    "mcp": "bun src/mcp/memory-server-canonical.ts",
    "mcp:canonical": "bun src/mcp/memory-server-canonical.ts",
    "mcp:dev": "bun --watch src/mcp/memory-server-canonical.ts",
    "mcp:http": "ALLURA_MCP_HTTP_PORT=${ALLURA_MCP_HTTP_PORT:-${CANONICAL_HTTP_PORT:-${OPENCLAW_PORT:-3201}}} bun src/mcp/canonical-http-gateway.ts",
    "mcp:legacy": "bun src/mcp/legacy/memory-server.ts",
    "mcp:legacy:http": "PORT=${OPENCLAW_PORT:-3200} bun src/mcp/legacy/openclaw-gateway-http.ts",
    "curator:run": "bun src/curator/index.ts run",
    "curator:approve": "bun src/curator/index.ts approve",
    "curator:reject": "bun src/curator/index.ts reject",
    "curator:watchdog": "bun src/curator/watchdog.ts",
    "curator:watchdog:dev": "bun --watch src/curator/watchdog.ts",
    "agent:create": "bun scripts/generate-agent.ts",
    "snapshot:build": "bun run scripts/build-memory-snapshot.ts",
    "session:hydrate": "bun run scripts/hydrate-session-from-snapshot.ts",
    "session:bootstrap": "bun run scripts/session-bootstrap.ts",
    "session:init": "bun run scripts/session-init.ts",
    "session:start": "bun run scripts/brooks-session-start.ts",
    "session:verify": "bun run scripts/verify-checkpoints.ts",
    "brooks": "bun run scripts/brooks-cli.ts",
    "brooks:start": "bun run scripts/brooks-cli.ts start",
    "brooks:status": "bun run scripts/brooks-cli.ts status",
    "brooks:end": "bun run scripts/brooks-cli.ts end",
    "openclaw:onboard": "bun run scripts/openclaw-onboard.ts",
    "whatsapp:setup": "bun run scripts/setup-whatsapp.ts",
    "telegram:setup": "bun run scripts/setup-telegram.ts",
    "registry:sync": "bun run scripts/opencode-registry/sync.ts",
    "registry:dry-run": "bun run scripts/opencode-registry/sync.ts --dry-run",
    "registry:log-audit": "bun run scripts/opencode-registry/log-audit.ts",
    "registry:drift": "bun run scripts/drift-detection.ts",
    "ports:check": "bun scripts/check-ports.ts",
    "ports:generate": "bun -e \"console.log(require('./src/lib/config/ports').generateEnvEntries(true))\"",
    "backfill:embeddings": "bun run src/curator/embedding-backfill-worker.ts --once",
    "backfill:embeddings:watch": "bun run src/curator/embedding-backfill-worker.ts --interval 30000",
    "load-test": "bash tests/load/run-load-test.sh"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@base-ui/react": "^1.0.0-beta.4",
    "@clerk/nextjs": "^7.0.12",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@hookform/resolvers": "^3.10.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@next/bundle-analyzer": "^15.3.1",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@vercel/otel": "^1.12.0",
    "@openai/agents": "^0.8.3",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/react-table": "^8.20.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dockerode": "^4.0.9",
    "embla-carousel-react": "^8.6.0",
    "geist": "^1.3.1",
    "input-otp": "^1.4.1",
    "lucide-react": "^0.511.0",
    "neo4j-driver": "^6.0.1",
    "next": "^16.0.0",
    "next-themes": "^0.4.6",
    "pg": "^8.16.3",
    "radix-ui": "^1.4.2",
    "react": "^19.2.0",
    "react-day-picker": "^9.8.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.56.4",
    "react-resizable-panels": "^2.1.7",
    "recharts": "^2.15.4",
    "server-only": "^0.0.1",
    "shadcn": "^4.1.2",
    "simple-icons": "^14.11.0",
    "sonner": "^2.0.1",
    "tailwind-merge": "^3.3.0",
    "tailwindcss": "4",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "yaml": "^2.8.3",
    "zod": "^4.1.5",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@opentelemetry/api": "1.7.0",
    "@opentelemetry/resources": "1.18.1",
    "@opentelemetry/sdk-node": "0.45.1",
    "@opentelemetry/sdk-trace-node": "1.18.1",
    "@opentelemetry/semantic-conventions": "1.40.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/bun": "^1.3.12",
    "@types/dockerode": "^4.0.1",
    "@types/glob": "^9.0.0",
    "@types/node": "^24.3.0",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "cross-env": "^7.0.3",
    "dotenv": "^17.3.1",
    "eslint": "^9.26.0",
    "eslint-config-next": "15.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-tailwindcss": "^3.18.2",
    "glob": "^13.0.6",
    "postcss-import": "^16.1.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.57.1",
    "vitest": "^2.1.9"
  }
}
