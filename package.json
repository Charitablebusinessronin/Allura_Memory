{
  "name": "memory",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "RUN_E2E_TESTS=true vitest run src/__tests__/e2e-integration.test.ts",
    "benchmark": "node scripts/benchmark.js --events=1000 --batch=100",
    "docs": "node scripts/generate-docs.js",
    "lint": "next lint",
    "mcp": "npx tsx src/mcp/memory-server.ts",
    "mcp:dev": "npx tsx --watch src/mcp/memory-server.ts",
    "curator:run": "npx tsx src/curator/index.ts run",
    "curator:approve": "npx tsx src/curator/index.ts approve",
    "curator:reject": "npx tsx src/curator/index.ts reject",
    "agent:create": "npx tsx scripts/generate-agent.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.0.0-beta.4",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@hookform/resolvers": "^3.10.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@tanstack/react-table": "^8.20.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dockerode": "^4.0.9",
    "embla-carousel-react": "^8.6.0",
    "geist": "^1.3.1",
    "input-otp": "^1.4.1",
    "lucide-react": "^0.511.0",
    "neo4j-driver": "^6.0.1",
    "next": "^16.0.0",
    "next-themes": "^0.4.6",
    "pg": "^8.16.3",
    "radix-ui": "^1.4.2",
    "react": "^19.2.0",
    "react-day-picker": "^9.8.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.56.4",
    "react-resizable-panels": "^2.1.7",
    "recharts": "^2.15.4",
    "server-only": "^0.0.1",
    "simple-icons": "^14.11.0",
    "sonner": "^2.0.1",
    "tailwind-merge": "^3.3.0",
    "vaul": "^1.1.2",
    "zod": "^4.1.5",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@types/dockerode": "^4.0.1",
    "@types/node": "^24.3.0",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "dotenv": "^17.3.1",
    "typescript": "^5.9.2",
    "vitest": "^2.1.9"
  }
}
