FROM oven/bun:1 AS base

WORKDIR /app

COPY package.json ./
COPY tsconfig.json ./
COPY src ./src

RUN bun install

ENV NODE_ENV=production

# MCP is a stdio server — it needs stdin to stay alive.
# When run via docker-compose, keep the container running
# so it's available for HTTP gateway or exec-based tool calls.
COPY <<'EOF' /app/entrypoint.sh
#!/bin/sh
# Start the MCP HTTP gateway server
# This provides both stdio (for MCP protocol) and HTTP (for external access)
export ALLURA_MCP_HTTP_PORT=3201
export ALLURA_MCP_HTTP_ENABLED=true
bun src/mcp/memory-server-canonical.ts &
MCP_PID=$!

# Keep container alive
exec sleep infinity
EOF
RUN chmod +x /app/entrypoint.sh

EXPOSE 3201

CMD ["/app/entrypoint.sh"]
