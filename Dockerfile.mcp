FROM oven/bun:1 AS base

WORKDIR /app

COPY package.json ./
COPY tsconfig.json ./
COPY src ./src
COPY scripts ./scripts
# Skill MCP servers — launched via docker exec for MCP_DOCKER
COPY .opencode/skills/skill-neo4j-memory ./skills/skill-neo4j-memory
COPY .opencode/skills/skill-cypher-query ./skills/skill-cypher-query
COPY .opencode/skills/skill-database ./skills/skill-database

RUN bun install

ENV NODE_ENV=production

# The MCP container is a warm execution environment for docker exec-based
# stdio sessions. The actual MCP stdio server is launched on demand by the
# harness, not as a long-running background process inside the container.
COPY <<'EOF' /app/entrypoint.sh
#!/bin/sh
set -eu

# Keep the container alive as an execution target for docker exec-based MCP
# sessions. Readiness is checked via the compose healthcheck.
exec tail -f /dev/null
EOF
RUN chmod +x /app/entrypoint.sh

# Skill launcher — used by MCP_DOCKER to spawn skill servers via docker exec
COPY <<'EOF' /app/skills/launch-skill.sh
#!/bin/sh
set -eu

SKILL_NAME="${1:?Usage: launch-skill.sh <skill-name>}"
shift

case "$SKILL_NAME" in
  skill-neo4j-memory)
    exec bun run /app/skills/skill-neo4j-memory/src/index.ts "$@"
    ;;
  skill-cypher-query)
    exec bun run /app/skills/skill-cypher-query/src/index.ts "$@"
    ;;
  skill-database)
    exec bun run /app/skills/skill-database/src/index.ts "$@"
    ;;
  *)
    echo "Unknown skill: $SKILL_NAME" >&2
    exit 1
    ;;
esac
EOF
RUN chmod +x /app/skills/launch-skill.sh

EXPOSE 3201

CMD ["/app/entrypoint.sh"]
