# Allura Memory — Base Environment
# Secrets go in .env.local (gitignored)

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=memory
POSTGRES_USER=ronin4life
POSTGRES_POOL_MAX=10

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_DATABASE=neo4j

# Ollama
OLLAMA_CLOUD_URL=https://ollama.com

# Governance
PROMOTION_MODE=soc2
AUTO_APPROVAL_THRESHOLD=0.85

# Allura MCP HTTP
ALLURA_MCP_HTTP_PORT=3201
ALLURA_DEV_AUTH_ENABLED=true
ALLURA_DEV_AUTH_ROLE=admin
ALLURA_DEV_AUTH_GROUP_ID=allura-system

# Embedding
EMBEDDING_BASE_URL=http://host.docker.internal:11434